# Copy to .env and fill in as needed:  cp .env.example .env
# The app runs with NONE of the LLM/Clerk keys set — the report falls back to a
# deterministic text bank and the coach gate shows a setup notice.

# ── Database ────────────────────────────────────────────────────────────────
# Postgres credentials, consumed by the `db` service.
POSTGRES_USER=bigfive
POSTGRES_PASSWORD=bigfive
POSTGRES_DB=bigfive

# Async SQLAlchemy URL used by the backend. In Docker Compose the host is the
# `db` service name; for host-run dev use localhost.
DATABASE_URL=postgresql+asyncpg://bigfive:bigfive@db:5432/bigfive

# ── Host ports (optional) ───────────────────────────────────────────────────
# Override only if the defaults clash with something already running locally.
# These affect the host side of the port mapping, not the in-container ports.
# DB_PORT=5432
# BACKEND_PORT=8000
# FRONTEND_PORT=5173

# ── Vertex AI (optional — coach & report narrative) ─────────────────────────
# Google Cloud project that hosts the Vertex AI models.
GOOGLE_CLOUD_PROJECT=
# Vertex AI region (e.g. us-central1).
VERTEX_LOCATION=us-central1

# ── Clerk (optional — Coach account gate) ───────────────────────────────────
# Backend secret key (sk_test_… from a Clerk Development instance).
CLERK_SECRET_KEY=
# Frontend publishable key (pk_test_…), exposed to the Vite build.
VITE_CLERK_PUBLISHABLE_KEY=

# ── Test mode (optional — dev only) ─────────────────────────────────────────
# When true, the UI exposes hidden testing controls: an "Autofill & finish"
# button on the question screen (fills all remaining Items via the normal answer
# path, then jumps to scoring → report) and demographics prefill on the start
# screen. Off by default; wired up in PR3. Never enable in production.
VITE_TEST_MODE=false
